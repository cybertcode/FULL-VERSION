# ⚠️ EN PRODUCCIÓN: APP_ENV=production, APP_DEBUG=false (evita filtrar stack traces al público)
APP_NAME="Mi Aplicación"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION=1.0.0

# IMPORTANTE: Mantener en 'en' — el customizer de Vuexy solo soporta: en, fr, ar, de
# Los mensajes en español se manejan vía lang/es/ en los Form Requests
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_PE
APP_TIMEZONE=America/Lima

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# ⚠️ EN PRODUCCIÓN: usar 'error' (debug expone SQL, payloads y trazas internas en storage/logs)
LOG_LEVEL=debug

# Días de retención del registro de auditoría (activity_log). Se purga automáticamente
# cada domingo (routes/console.php, activitylog:clean) — ver /admin/auditoria
ACTIVITY_LOGGER_RETENTION_DAYS=365

# ---------------------------------------------------------------
# Base de datos — MySQL (Laragon local / producción)
# ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nombre_db
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------
# Sesión, cache y queue
# ---------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# En producción con HTTPS, poner en true para que la cookie de sesión solo viaje por SSL.
# Dejar en null solo si el hosting no garantiza HTTPS (ej. shared hosting sin SSL forzado).
SESSION_SECURE_COOKIE=null

# Orígenes permitidos para consumir /api/v1 desde un frontend externo (SPA, app móvil vía WebView, etc.)
# Lista separada por comas, sin espacios. Vacío = ningún origen externo permitido.
# Ejemplo: CORS_ALLOWED_ORIGINS=https://app.midominio.com,https://midominio.com
CORS_ALLOWED_ORIGINS=

# Dominios que pueden autenticarse por cookie de sesión (SPA propia) contra /api/v1 vía Sanctum.
# Lista separada por comas, sin protocolo. Dejar vacío si /api/v1 solo se consume con token Bearer.
SANCTUM_STATEFUL_DOMAINS=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# ---------------------------------------------------------------
# Mail
# ---------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# NOTA: el login social (Google/GitHub/Facebook) NO se configura por .env.
# Client ID/Secret se guardan cifrados en Settings → /admin/configuracion → Integraciones.
# El botón de cada proveedor solo aparece si esas dos claves están configuradas ahí.

# ---------------------------------------------------------------
# Backups automáticos (spatie/laravel-backup) — ver routes/console.php
# ---------------------------------------------------------------
BACKUP_NOTIFICATION_EMAIL=
BACKUP_ARCHIVE_PASSWORD=

# ---------------------------------------------------------------
# Uploads (config/app-settings.php)
# ---------------------------------------------------------------
UPLOAD_DISK=public

# ---------------------------------------------------------------
# Moneda (config/app-settings.php)
# ---------------------------------------------------------------
APP_CURRENCY_SYMBOL="S/"

# ---------------------------------------------------------------
# Redis (opcional — para cache/queue en producción)
# ---------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------
# AWS S3 (opcional — storage en producción)
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
