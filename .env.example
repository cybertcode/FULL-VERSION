APP_NAME="Mi Aplicación"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# IMPORTANTE: Mantener en 'en' — el customizer de Vuexy solo soporta: en, fr, ar, de
# Los mensajes en español se manejan vía lang/es/ en los Form Requests
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_PE
APP_TIMEZONE=America/Lima

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------
# Base de datos — MySQL (Laragon local / producción)
# ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nombre_db
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------
# Sesión, cache y queue
# ---------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# ---------------------------------------------------------------
# Mail
# ---------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------
# Uploads (config/app-settings.php)
# ---------------------------------------------------------------
UPLOAD_DISK=public

# ---------------------------------------------------------------
# Moneda (config/app-settings.php)
# ---------------------------------------------------------------
APP_CURRENCY_SYMBOL="S/"

# ---------------------------------------------------------------
# Redis (opcional — para cache/queue en producción)
# ---------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------
# AWS S3 (opcional — storage en producción)
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
